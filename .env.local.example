# Portfolio Configuration
# Copy this file to .env.local and set your own values

# Admin password for editing your portfolio
NEXT_PUBLIC_ADMIN_PASSWORD=your-secure-password-here

# Optional: Your portfolio owner name (overrides default)
NEXT_PUBLIC_PORTFOLIO_NAME=Your Name

# Supabase Configuration (for cross-device sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key